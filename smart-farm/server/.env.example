# ============================================================
#  Smart Farm Server - ตั้งค่าก่อนใช้งาน
#  คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าต่างๆ
# ============================================================

# ชื่อผู้ใช้และรหัสผ่านสำหรับเข้าระบบ
ADMIN_USER=admin
ADMIN_PASS=farm1234

# Secret key สำหรับ session (เปลี่ยนเป็นค่าสุ่มที่คาดเดายาก)
SESSION_SECRET=smart-farm-secret-key-change-this-to-random-string

# Port (Railway/Render จะกำหนดให้อัตโนมัติ ไม่ต้องแก้)
PORT=3000
